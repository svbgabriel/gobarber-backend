{
  "compilerOptions": {
    /* Basic Options */
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "types": [
      "cors",
      "express",
      "jsonwebtoken",
      "multer",
      "node",
      "nodemailer",
      "pg",
      "supertest",
      "vitest/globals",
    ],
    "allowJs": false,

    /* Workspace Settings */
    "composite": true,

    /* Strict Type-Checking Options */
    "strict": true,

    /* Module Resolution Options */
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "sourceMap": true,

    "declaration": true,

    /* Advanced Options */
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
  },
}
